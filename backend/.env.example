# Environment mode: development | production
NODE_ENV=development

# Port to listen on
PORT=3001

# PostgreSQL database connection string
DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/seapedia

# JWT Secret key for signing session tokens
JWT_SECRET=supersecretjwtkeyplaceholderchangeinproduction

# Allowed CORS origin (single URL)
FRONTEND_URL=http://localhost:5173
