{
  "name": "seapedia-backend",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "deploy": "echo 'Deploy via Docker'",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "fl": "bun run format && bun run lint",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/zod-openapi": "latest",
    "@scalar/hono-api-reference": "latest",
    "@t3-oss/env-core": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "hono-openapi": "latest",
    "jose": "latest",
    "postgres": "latest",
    "zod": "latest",
    "zod-openapi": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "latest"
  }
}
